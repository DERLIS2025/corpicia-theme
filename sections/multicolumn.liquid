{{ 'section-multicolumn.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  /* ============================================
     CORPI & CIA - MULTICOLUMN MEJORADO
     Grid simétrico garantizado
     ============================================ */

  /* Grid mejorado con gap dinámico */
  .section-{{ section.id }}-padding .multicolumn-list {
    gap: 2rem;
    row-gap: 1,3rem;
    /* Asegurar que siempre se vea bien alineado */
    justify-content: center;
  }

  @media screen and (min-width: 990px) {
    .section-{{ section.id }}-padding .multicolumn-list {
      gap: 2.5rem;
      row-gap: 3.5rem;
    }
  }

  /* Centrar últimos elementos cuando no completan la fila */
  .section-{{ section.id }}-padding .multicolumn-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
  }

  .section-{{ section.id }}-padding .multicolumn-list__item {
    flex: 0 0 auto;
    width: 100%;
  }

  /* Mobile: 1 columna, mostrando parcialmente el siguiente */
  @media screen and (max-width: 749px) {
    .section-{{ section.id }}-padding .multicolumn-list {
      display: flex;
      flex-wrap: nowrap;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      -ms-overflow-style: none;
      padding-bottom: 1rem;
      justify-content: flex-start;
    }

    .section-{{ section.id }}-padding .multicolumn-list::-webkit-scrollbar {
      display: none;
    }

    .section-{{ section.id }}-padding .multicolumn-list__item {
      width: 85vw;
      max-width: 320px;
      scroll-snap-align: start;
    }

    .section-{{ section.id }}-padding .multicolumn-list__item:last-child {
      margin-right: 5vw;
    }
  }

  /* Tablet: 2 columnas simétrico */
  @media screen and (min-width: 750px) and (max-width: 989px) {
    .section-{{ section.id }}-padding .multicolumn-list {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
    }
    
    .section-{{ section.id }}-padding .multicolumn-list__item {
      width: auto;
    }
  }

  /* Desktop: Grid configurable pero centrado */
  @media screen and (min-width: 990px) {
    .section-{{ section.id }}-padding .multicolumn-list {
      display: grid;
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
      justify-items: center;
    }

    .section-{{ section.id }}-padding .multicolumn-list__item {
      width: 100%;
      max-width: 380px; /* Limitar ancho máximo para no estirar demasiado */
    }

    /* Si hay elementos sueltos en la última fila, centrar el grid */
    .section-{{ section.id }}-padding .multicolumn-list::after {
      content: '';
      flex: auto;
    }
  }

  /* Tarjeta con sombra suave y bordes redondeados */
  .section-{{ section.id }}-padding .multicolumn-card {
    background: rgb(var(--color-background));
    border-radius: 16px;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    height: 100%;
    display: flex;
    flex-direction: column;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
    border: 1px solid rgba(0, 0, 0, 0.06);
  }

  .section-{{ section.id }}-padding .multicolumn-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.12);
    border-color: transparent;
  }

  /* Wrapper de imagen con aspect ratio consistente */
  .section-{{ section.id }}-padding .multicolumn-card__image-wrapper {
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  }

  .section-{{ section.id }}-padding .multicolumn-card__image-wrapper::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 40%;
    background: linear-gradient(to top, rgba(0,0,0,0.03), transparent);
    pointer-events: none;
  }

  /* Imagen con zoom suave en hover */
  .section-{{ section.id }}-padding .multicolumn-card__image {
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .section-{{ section.id }}-padding .multicolumn-card:hover .multicolumn-card__image {
    transform: scale(1.08);
  }

  /* Info de la tarjeta mejorada */
  .section-{{ section.id }}-padding .multicolumn-card__info {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    gap: 0.75rem;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding .multicolumn-card__info {
      padding: 2rem;
    }
  }

  /* Título con mejor tipografía */
  .section-{{ section.id }}-padding .multicolumn-card__info h3 {
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.3;
    margin: 0;
    color: rgb(var(--color-foreground));
    letter-spacing: -0.02em;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding .multicolumn-card__info h3 {
      font-size: 1.25rem;
    }
  }

  /* Descripción */
  .section-{{ section.id }}-padding .multicolumn-card__info .rte {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: rgba(var(--color-foreground), 0.7);
    margin: 0;
  }

  /* Link/Botón estilizado como CTA */
  .section-{{ section.id }}-padding .multicolumn-card__info .link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: auto;
    padding-top: 1rem;
    font-weight: 600;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: rgb(var(--color-link));
    transition: gap 0.3s ease;
  }

  .section-{{ section.id }}-padding .multicolumn-card__info .link:hover {
    gap: 0.75rem;
  }

  .section-{{ section.id }}-padding .multicolumn-card__info .link .icon-wrap {
    display: inline-flex;
    transition: transform 0.3s ease;
  }

  .section-{{ section.id }}-padding .multicolumn-card__info .link:hover .icon-wrap {
    transform: translateX(4px);
  }

  /* ============================================
     NAVEGACIÓN MOBILE RE-DISEÑADA
     ============================================ */

  .section-{{ section.id }}-padding .slider-buttons {
    display: none;
  }

  @media screen and (max-width: 989px) {
    .section-{{ section.id }}-padding .multicolumn-mobile-nav {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      margin-top: 2.5rem;
      padding: 0 1rem;
    }

    .section-{{ section.id }}-padding .multicolumn-mobile-nav__btn {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      border: 2px solid rgba(var(--color-foreground), 0.15);
      background: rgb(var(--color-background));
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: all 0.3s ease;
      flex-shrink: 0;
    }

    .section-{{ section.id }}-padding .multicolumn-mobile-nav__btn:hover {
      border-color: rgb(var(--color-foreground));
      background: rgb(var(--color-foreground));
      color: rgb(var(--color-background));
    }

    .section-{{ section.id }}-padding .multicolumn-mobile-nav__btn svg {
      width: 20px;
      height: 20px;
    }

    .section-{{ section.id }}-padding .multicolumn-dots {
      display: flex;
      gap: 0.5rem;
      align-items: center;
    }

    .section-{{ section.id }}-padding .multicolumn-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: rgba(var(--color-foreground), 0.2);
      transition: all 0.3s ease;
      cursor: pointer;
      border: none;
      padding: 0;
    }

    .section-{{ section.id }}-padding .multicolumn-dot.active {
      width: 24px;
      border-radius: 4px;
      background: rgb(var(--color-foreground));
    }

    .section-{{ section.id }}-padding .multicolumn-counter {
      font-size: 0.875rem;
      font-weight: 500;
      color: rgba(var(--color-foreground), 0.6);
      min-width: 3rem;
      text-align: center;
    }
  }

  @media screen and (min-width: 990px) {
    .section-{{ section.id }}-padding .multicolumn-mobile-nav {
      display: none;
    }
  }

  /* ============================================
     BADGE "POPULAR" OPCIONAL
     ============================================ */
  .section-{{ section.id }}-padding .multicolumn-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background: #2E7D32;
    color: white;
    padding: 0.375rem 0.875rem;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    z-index: 2;
    box-shadow: 0 4px 12px rgba(46, 125, 50, 0.3);
  }

  /* Ajustes responsive generales */
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Mejora de accesibilidad */
  .section-{{ section.id }}-padding .multicolumn-card:focus-within {
    outline: 2px solid rgb(var(--color-foreground));
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .section-{{ section.id }}-padding .multicolumn-card,
    .section-{{ section.id }}-padding .multicolumn-card__image,
    .section-{{ section.id }}-padding .link,
    .section-{{ section.id }}-padding .multicolumn-mobile-nav__btn {
      transition: none;
    }
    
    .section-{{ section.id }}-padding .multicolumn-card:hover {
      transform: none;
    }
  }
{%- endstyle -%}

{%- liquid
  assign columns_mobile_int = section.settings.columns_mobile | plus: 0
  assign show_mobile_slider = false
  if section.settings.swipe_on_mobile and section.blocks.size > columns_mobile_int
    assign show_mobile_slider = true
  endif
-%}

<div class="multicolumn color-{{ section.settings.color_scheme }} gradient{% unless section.settings.background_style == 'none' and settings.text_boxes_border_thickness > 0 or settings.text_boxes_shadow_opacity > 0 %} background-{{ section.settings.background_style }}{% endunless %}{% if section.settings.title == blank %} no-heading{% endif %}">
  <div
    class="page-width section-{{ section.id }}-padding isolate{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
    {% if settings.animations_reveal_on_scroll %}
      data-cascade
    {% endif %}
  >
    {%- unless section.settings.title == blank -%}
      <div class="title-wrapper-with-link title-wrapper--self-padded-mobile title-wrapper--no-top-margin multicolumn__title">
        <h2 class="title inline-richtext {{ section.settings.heading_size }}">
          {{ section.settings.title }}
        </h2>
        {%- if section.settings.button_label != blank and show_mobile_slider -%}
          <a href="{{ section.settings.button_link }}" class="link underlined-link large-up-hide">
            {{- section.settings.button_label | escape -}}
          </a>
        {%- endif -%}
      </div>
    {%- endunless -%}

    <slider-component class="slider-mobile-gutter">
      <ul
        class="multicolumn-list contains-content-container{% if show_mobile_slider %} slider slider--tablet grid--peek{% endif %}"
        id="Slider-{{ section.id }}"
        role="list"
      >
        {%- liquid
          assign highest_ratio = 0
          for block in section.blocks
            if block.settings.image.aspect_ratio > highest_ratio
              assign highest_ratio = block.settings.image.aspect_ratio
            endif
          endfor
        -%}
        {%- for block in section.blocks -%}
          {%- assign empty_column = '' -%}
          {%- if block.settings.image == blank
            and block.settings.title == blank
            and block.settings.text == blank
            and block.settings.link_label == blank
          -%}
            {%- assign empty_column = ' multicolumn-list__item--empty' -%}
          {%- endif -%}

          <li
            id="Slide-{{ section.id }}-{{ forloop.index }}"
            class="multicolumn-list__item grid__item{% if section.settings.swipe_on_mobile %} slider__slide{% endif %}{% if section.settings.column_alignment == 'center' %} center{% endif %}{{ empty_column }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {{ block.shopify_attributes }}
            {% if settings.animations_reveal_on_scroll %}
              data-cascade
              style="--animation-order: {{ forloop.index }};"
            {% endif %}
          >
            <div class="multicolumn-card content-container">
              {%- if block.settings.image != blank -%}
                {% if section.settings.image_ratio == 'adapt' or section.settings.image_ratio == 'circle' %}
                  {% assign spaced_image = true %}
                {% endif %}
                <div class="multicolumn-card__image-wrapper multicolumn-card__image-wrapper--{{ section.settings.image_width }}-width{% if section.settings.image_width != 'full' or spaced_image %} multicolumn-card-spacing{% endif %}">
                  {%- if forloop.first and section.settings.show_badge -%}
                    <span class="multicolumn-badge">Más Popular</span>
                  {%- endif -%}
                  <div
                    class="media media--transparent media--{{ section.settings.image_ratio }}"
                    {% if section.settings.image_ratio == 'adapt' %}
                      style="padding-bottom: {{ 1 | divided_by: highest_ratio | times: 100 }}%;"
                    {% endif %}
                  >
                    {%- liquid
                      assign number_of_columns = section.settings.columns_desktop
                      assign number_of_columns_mobile = section.settings.columns_mobile
                      assign grid_space_desktop = number_of_columns | minus: 1 | times: settings.spacing_grid_horizontal | plus: 100 | append: 'px'
                      assign grid_space_tablet = number_of_columns_mobile | minus: 1 | times: settings.spacing_grid_horizontal | plus: 100 | append: 'px'
                      assign grid_space_mobile = number_of_columns_mobile | minus: 1 | times: settings.spacing_grid_horizontal | divided_by: 2 | plus: 30 | append: 'px'
                      if section.settings.image_width == 'half'
                        assign image_width = 0.5
                      elsif section.settings.image_width == 'third'
                        assign image_width = 0.33
                      else
                        assign image_width = 1
                      endif
                    -%}
                    {% capture sizes %}
                      (min-width: {{ settings.page_width }}px) calc(({{ settings.page_width }}px - {{ grid_space_desktop }}) * {{ image_width }} /  {{ number_of_columns }}),
                      (min-width: 990px) calc((100vw - {{ grid_space_desktop }}) * {{ image_width }} / {{ number_of_columns }}),
                      (min-width: 750px) calc((100vw - {{ grid_space_tablet }}) * {{ image_width }} / {{ number_of_columns_mobile }}),
                      calc((100vw - {{ grid_space_mobile }}) * {{ image_width }} / {{ number_of_columns_mobile }})
                    {% endcapture %}
                    {{
                      block.settings.image
                      | image_url: width: 3200
                      | image_tag:
                        widths: '50, 75, 100, 150, 200, 300, 400, 500, 750, 1000, 1250, 1500, 1750, 2000, 2250, 2500, 2750, 3000, 3200',
                        sizes: sizes,
                        class: 'multicolumn-card__image',
                        loading: 'lazy'
                    }}
                  </div>
                </div>
              {%- endif -%}
              <div class="multicolumn-card__info">
                {%- if block.settings.title != blank -%}
                  <h3 class="inline-richtext">{{ block.settings.title }}</h3>
                {%- endif -%}
                {%- if block.settings.text != blank -%}
                  <div class="rte">{{ block.settings.text }}</div>
                {%- endif -%}
                {%- if block.settings.link_label != blank -%}
                  <a
                    class="link animate-arrow"
                    {% if block.settings.link == blank %}
                      role="link" aria-disabled="true"
                    {% else %}
                      href="{{ block.settings.link }}"
                    {% endif %}
                    aria-label="{{ block.settings.link_label | escape }} - {{ block.settings.title | escape }}"
                  >
                    {{- block.settings.link_label | escape -}}
                    <span class="svg-wrapper">
                      <span class="icon-wrap">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <line x1="5" y1="12" x2="19" y2="12"></line>
                          <polyline points="12 5 19 12 12 19"></polyline>
                        </svg>
                      </span>
                    </span>
                  </a>
                {%- endif -%}
              </div>
            </div>
          </li>
        {%- endfor -%}
      </ul>

      {%- if show_mobile_slider -%}
        <div class="multicolumn-mobile-nav large-up-hide">
          <button
            type="button"
            class="multicolumn-mobile-nav__btn"
            data-direction="prev"
            aria-label="{{ 'general.slider.previous_slide' | t }}"
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
            </svg>
          </button>
          
          <div class="multicolumn-dots" id="Dots-{{ section.id }}">
            {%- for block in section.blocks -%}
              <button 
                class="multicolumn-dot{% if forloop.first %} active{% endif %}" 
                data-index="{{ forloop.index0 }}"
                aria-label="Ir a slide {{ forloop.index }}"
                aria-current="{% if forloop.first %}true{% else %}false{% endif %}"
              ></button>
            {%- endfor -%}
          </div>

          <span class="multicolumn-counter" id="Counter-{{ section.id }}">
            <span class="current">1</span> / {{ section.blocks.size }}
          </span>

          <button
            type="button"
            class="multicolumn-mobile-nav__btn"
            data-direction="next"
            aria-label="{{ 'general.slider.next_slide' | t }}"
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </button>
        </div>

        <script>
          (function() {
            const slider = document.getElementById('Slider-{{ section.id }}');
            const dots = document.querySelectorAll('#Dots-{{ section.id }} .multicolumn-dot');
            const counterCurrent = document.querySelector('#Counter-{{ section.id }} .current');
            const prevBtn = document.querySelector('[data-direction="prev"]');
            const nextBtn = document.querySelector('[data-direction="next"]');
            
            let currentIndex = 0;
            const totalSlides = {{ section.blocks.size }};
            const slideWidth = slider.querySelector('.multicolumn-list__item').offsetWidth + 32;

            function updateSlider(index) {
              currentIndex = index;
              slider.scrollTo({
                left: slideWidth * index,
                behavior: 'smooth'
              });
              
              dots.forEach((dot, i) => {
                dot.classList.toggle('active', i === index);
                dot.setAttribute('aria-current', i === index ? 'true' : 'false');
              });
              
              counterCurrent.textContent = index + 1;
            }

            prevBtn.addEventListener('click', () => {
              if (currentIndex > 0) updateSlider(currentIndex - 1);
            });
            
            nextBtn.addEventListener('click', () => {
              if (currentIndex < totalSlides - 1) updateSlider(currentIndex + 1);
            });

            dots.forEach((dot, index) => {
              dot.addEventListener('click', () => updateSlider(index));
            });

            let isDown = false;
            let startX;
            let scrollLeft;

            slider.addEventListener('mousedown', (e) => {
              isDown = true;
              startX = e.pageX - slider.offsetLeft;
              scrollLeft = slider.scrollLeft;
            });

            slider.addEventListener('mouseleave', () => isDown = false);
            slider.addEventListener('mouseup', () => {
              isDown = false;
              const newIndex = Math.round(slider.scrollLeft / slideWidth);
              if (newIndex !== currentIndex) updateSlider(newIndex);
            });

            slider.addEventListener('mousemove', (e) => {
              if (!isDown) return;
              e.preventDefault();
              const x = e.pageX - slider.offsetLeft;
              const walk = (x - startX) * 2;
              slider.scrollLeft = scrollLeft - walk;
            });

            slider.addEventListener('scroll', () => {
              const newIndex = Math.round(slider.scrollLeft / slideWidth);
              if (newIndex !== currentIndex && newIndex >= 0 && newIndex < totalSlides) {
                currentIndex = newIndex;
                dots.forEach((dot, i) => {
                  dot.classList.toggle('active', i === currentIndex);
                  dot.setAttribute('aria-current', i === currentIndex ? 'true' : 'false');
                });
                counterCurrent.textContent = currentIndex + 1;
              }
            }, { passive: true });
          })();
        </script>
      {%- endif -%}
    </slider-component>

    <div class="center{% if show_mobile_slider %} small-hide medium-hide{% endif %}">
      {%- if section.settings.button_label != blank -%}
        <a
          class="button button--primary"
          {% if section.settings.button_link == blank %}
            role="link" aria-disabled="true"
          {% else %}
            href="{{ section.settings.button_link }}"
          {% endif %}
        >
          {{ section.settings.button_label | escape }}
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.multicolumn.name",
  "class": "section",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "t:sections.multicolumn.settings.title.default",
      "label": "t:sections.multicolumn.settings.title.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.options__3.label"
        },
        {
          "value": "hxl",
          "label": "t:sections.all.heading_size.options__4.label"
        },
        {
          "value": "hxxl",
          "label": "t:sections.all.heading_size.options__5.label"
        }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "header",
      "content": "t:sections.multicolumn.settings.header_image.content"
    },
    {
      "type": "checkbox",
      "id": "show_badge",
      "default": false,
      "label": "Mostrar badge 'Más Popular' en el primer item",
      "info": "Destaca visualmente el producto más solicitado"
    },
    {
      "type": "select",
      "id": "image_width",
      "options": [
        {
          "value": "third",
          "label": "t:sections.multicolumn.settings.image_width.options__1.label"
        },
        {
          "value": "half",
          "label": "t:sections.multicolumn.settings.image_width.options__2.label"
        },
        {
          "value": "full",
          "label": "t:sections.multicolumn.settings.image_width.options__3.label"
        }
      ],
      "default": "full",
      "label": "t:sections.multicolumn.settings.image_width.label"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:sections.multicolumn.settings.image_ratio.options__1.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.multicolumn.settings.image_ratio.options__2.label"
        },
