se;\n    font-family: sans-serif;\n    margin-bottom: 12px;\n    position: relative;\n    box-shadow: 0 4px 15px rgba(0,0,0,0.1);\n    white-space: nowrap;\n    border: 1px solid #eee;\n  }\n\n  .bocadillo-ui::after {\n    content: '';\n    position: absolute;\n    bottom: -8px;\n    left: 50%;\n    transform: translateX(-50%);\n    border-top: 8px solid #ffffff;\n    border-left: 8px solid transparent;\n    border-right: 8px solid transparent;\n  }\n\n  .avatar-img {\n    width: 90px;\n    image-rendering: pixelated;\n    animation: rebote-paso 0.8s steps(2) infinite;\n  }\n\n  .sombra-contacto {\n    width: 60px;\n    height: 8px;\n    background: rgba(0,0,0,0.3);\n    border-radius: 50%;\n    filter: blur(4px);\n    margin-top: -10px;\n  }\n\n  \/* ANIMACIONES *\/\n  @keyframes caminar-lento {\n    0% { left: -300px; }\n    100% { left: 115%; }\n  }\n\n  @keyframes efecto-corte-real {\n    0% { transform: scaleX(1); }\n    100% { transform: scaleX(0); }\n  }\n\n  @keyframes rebote-paso {\n    0%, 100% { transform: translateY(0); }\n    50% { transform: translateY(-3px); }\n  }\n\n  \/* RESPONSIVE *\/\n  @media (max-width: 767px) {\n    .contenedor-jardin-corpi { \n      height: 125px; \/* Ajuste para que el fondo no se estire en celulares *\/\n    }\n    .jardinero-cortando, .personita-regando, .capa-pasto-alto {\n      animation-duration: 22s;\n    }\n    .personita-regando { animation-delay: -4s; }\n    .avatar-img { width: 65px; }\n    .bocadillo-ui { font-size: 10px; padding: 6px 12px; }\n  }\n<\/style>\n\n<div class=\"contenedor-jardin-corpi\">\n  <div class=\"capa-pasto-alto\"><\/div>\n\n  <div class=\"trabajador-wrap jardinero-cortando\">\n    <div class=\"bocadillo-ui\">Agenda tu mantenimiento hoy<\/div>\n    <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0741\/0198\/1441\/files\/Gemini_Generated_Image_yyu5bgyyu5bgyyu5-removebg-preview.png?v=1770842459\" \n         class=\"avatar-img\" alt=\"Jardinero Cortando\">\n    <div class=\"sombra-contacto\"><\/div>\n  <\/div>\n\n  <div class=\"trabajador-wrap personita-regando\">\n    <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0741\/0198\/1441\/files\/Gemini_Generated_Image_pl15nepl15nepl15-removebg-preview.png?v=1770907575\" \n         class=\"avatar-img\" alt=\"Personita Regando\">\n    <div class=\"sombra-contacto\"><\/div>\n  <\/div>\n<\/div>","color_scheme":"scheme-1","padding_top":0,"padding_bottom":0}}},"order":["slideshow","collection_slider_corpicia_UPLTra","featured-collection","slideshow_Kgftmc","featured_collection_Gq8Hqg","image_with_text_xGBAGT","featured_collection_JLqzph","slideshow_gHH6Xe","multicolumn_JWeHGy","1768229758cdf74d1f","1768790699fd777679","custom_liquid_txWwqz"]}