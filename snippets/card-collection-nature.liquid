{% comment %}
  Tarjeta colección CUADRADA 1:1 - Corpicia
{% endcomment %}

{%- liquid
  if title != blank
    assign display_title = title
  elsif collection != blank
    assign display_title = collection.title
  else
    assign display_title = 'Colección'
  endif
  
  assign display_image = featured_image
  if display_image == blank and collection != blank
    assign display_image = collection.featured_image
  endif
  
  assign collection_url = collection.url | default: '#'
-%}

<div class="nature-card">
  <a href="{{ collection_url }}" class="block" style="text-decoration: none;">
    
    <div class="nature-image-wrapper">
      {%- if display_image != blank -%}
        <img 
          src="{{ display_image | image_url: width: 600, height: 600, crop: 'center' }}" 
          alt="{{ display_title }}"
          loading="lazy"
          class="nature-image"
          width="600" 
          height="600"
        >
      {%- else -%}
        <div class="nature-placeholder">
          <span>Sin imagen</span>
        </div>
      {%- endif -%}
      
      {%- if badge != blank -%}
        <span class="nature-badge">{{ badge }}</span>
      {%- endif -%}
    </div>
    
    <div class="nature-content">
      <h3 class="nature-title">{{ display_title | escape }}</h3>
    </div>
    
  </a>
</div>

<style>
  .nature-card {
    width: 100%;
    transition: transform 0.3s ease;
  }
  
  .nature-card a {
    text-decoration: none;
    color: inherit;
  }
  
  .nature-card:hover {
    transform: translateY(-5px);
  }
  
  .nature-image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    background: #f5f5f5;
    border-radius: 1rem;
    overflow: hidden;
  }
  
  .nature-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  
  .nature-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #999;
    font-size: 14px;
  }
  
  .nature-badge {
    position: absolute;
    top: 8px;
    right: 8px;
    background: #22c55e;
    color: white;
    font-size: 12px;
    font-weight: bold;
    padding: 4px 12px;
    border-radius: 9999px;
  }
  
  .nature-content {
    text-align: center;
    margin-top: 12px;
    padding: 0 8px;
  }
  
  .nature-title {
    margin: 0;
    font-size: 16px;
    font-weight: 600;
    color: #1f2937;
    line-height: 1.4;
    min-height: 2.8em;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  
  .nature-card:hover .nature-image-wrapper {
    box-shadow: 0 10px 30px rgba(0,0,0,0.15);
  }
</style>