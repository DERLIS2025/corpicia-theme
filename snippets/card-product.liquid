{%- comment %}
  Renders a product card - CORPI & CIA REDESIGN v3.5
  Cambios: Badge SEO de instalación incluido para productos específicos de césped.
{%- endcomment %}

{%- unless skip_styles -%}
  {{ 'component-rating.css' | asset_url | stylesheet_tag }}
  {{ 'component-volume-pricing.css' | asset_url | stylesheet_tag }}
  {{ 'component-price.css' | asset_url | stylesheet_tag }}
  {{ 'quick-order-list.css' | asset_url | stylesheet_tag }}
  {{ 'quantity-popover.css' | asset_url | stylesheet_tag }}
{%- endunless -%}

{%- style -%}
  /* ========================================
     CORPI & CIA - PRODUCT CARD REDESIGN v3.4
     ======================================== */
  
  .card-product-corpi {
    position: relative;
    background: #ffffff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    transition: all 0.3s ease;
    height: 100%;
    display: flex;
    flex-direction: column;
    border: 1px solid #f0f0f0;
  }
  
  .card-product-corpi:hover {
    box-shadow: 0 8px 30px rgba(0,0,0,0.12);
    transform: translateY(-4px);
  }
  
  /* IMAGEN CONTAINER */
  .card-product-corpi__media-wrapper {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    background: #f8f8f8;
  }
  
  .card-product-corpi__media-wrapper a {
    display: block;
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }
  
  .card-product-corpi__media {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  
  .card-product-corpi:hover .card-product-corpi__media {
    transform: scale(1.05);
  }
  
  /* BADGE OFERTA */
  .card-product-corpi__badge-offer {
    position: absolute;
    top: 12px;
    left: 12px;
    background: #e53935;
    color: white;
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: 12px;
    padding: 8px 16px;
    border-radius: 20px;
    z-index: 2;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    box-shadow: 0 2px 8px rgba(229, 57, 53, 0.3);
  }
  
  /* CONTENIDO */
  .card-product-corpi__content {
    padding: 20px;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  
  .card-product-corpi__title {
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: 15px;
    line-height: 1.4;
    color: #1a1a1a;
    margin: 0;
    text-decoration: none;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    min-height: 42px;
  }
  
  .card-product-corpi__title a {
    color: inherit;
    text-decoration: none;
  }
  
  .card-product-corpi__title a:hover {
    color: #1565C0;
  }
  
  /* PRECIOS */
  .card-product-corpi__prices {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  
  .card-product-corpi__price-compare {
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    color: #999;
    text-decoration: line-through;
    margin: 0;
  }
  
  .card-product-corpi__price-current {
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: 22px;
    color: #2E7D32;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  
  .card-product-corpi__price-label {
    font-size: 10px;
    font-weight: 700;
    color: #e53935;
    background: rgba(229, 57, 53, 0.1);
    padding: 3px 8px;
    border-radius: 10px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  
  .card-product-corpi__price-unit {
    font-size: 13px;
    font-weight: 500;
    color: #666;
  }
  
  /* BOTÓN VER DETALLES - BASE (Desktop) */
  .card-product-corpi__details-btn {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    gap: 8px !important;
    width: 100% !important; 
    padding: 12px 12px !important;
    background: #1565C0 !important;
    color: white !important;
    font-family: 'Montserrat', sans-serif !important;
    font-weight: 600 !important;
    font-size: 14px !important;
    text-decoration: none !important;
    border-radius: 10px !important;
    border: none !important;
    cursor: pointer !important;
    transition: all 0.3s ease !important;
    margin-top: 4px !important;
  }
  
  .card-product-corpi__details-btn:hover {
    background: #0D47A1 !important;
    transform: translateY(-2px) !important;
    box-shadow: 0 4px 12px rgba(21, 101, 192, 0.3) !important;
  }
  
  /* ACORDEÓN PRECIOS M² */
  .card-product-corpi__pricing-toggle {
    width: 100%;
    padding: 10px 14px;
    background: #f5f5f5;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    font-family: 'Montserrat', sans-serif;
    font-size: 12px;
    font-weight: 600;
    color: #333;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition: all 0.3s ease;
  }
  
  .card-product-corpi__pricing-toggle:hover {
    background: #eeeeee;
  }
  
  .card-product-corpi__pricing-toggle.active {
    background: #E3F2FD;
    border-color: #1565C0;
    color: #1565C0;
  }
  
  .card-product-corpi__pricing-toggle svg {
    width: 14px;
    height: 14px;
    transition: transform 0.3s ease;
  }
  
  .card-product-corpi__pricing-toggle.active svg {
    transform: rotate(180deg);
  }
  
  .card-product-corpi__pricing-panel {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s ease;
    background: #fafafa;
    border-radius: 0 0 8px 8px;
    margin-top: -4px;
  }
  
  .card-product-corpi__pricing-panel.open {
    max-height: 300px;
    padding: 14px;
    border: 1px solid #e0e0e0;
    border-top: none;
  }
  
  .card-product-corpi__pricing-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }
  
  .card-product-corpi__pricing-item {
    background: white;
    padding: 10px;
    border-radius: 6px;
    text-align: center;
    border: 1px solid #e0e0e0;
  }
  
  .card-product-corpi__pricing-qty {
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    color: #666;
    margin: 0 0 2px 0;
  }
  
  .card-product-corpi__pricing-value {
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    font-weight: 700;
    color: #2E7D32;
    margin: 0;
  }
  
  /* FEATURES */
  .card-product-corpi__features {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: auto;
    padding-top: 12px;
    border-top: 1px solid #f0f0f0;
  }
  
  .card-product-corpi__feature {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: 'Montserrat', sans-serif;
    font-size: 12px;
    color: #555;
    line-height: 1.3;
  }
  
  .card-product-corpi__feature svg {
    width: 16px;
    height: 16px;
    color: #2E7D32;
    flex-shrink: 0;
  }
  
  /* BANNER COMERCIAL CÉSPED */
  .card-product-corpi__commercial-banner {
    background: linear-gradient(135deg, #2E7D32 0%, #43A047 100%);
    color: white;
    padding: 10px 12px;
    border-radius: 8px;
  }
  
  .card-product-corpi__commercial-text {
    font-family: 'Montserrat', sans-serif;
    font-size: 12px;
    font-weight: 700;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 6px;
    justify-content: center;
    text-align: center;
  }
  
  .card-product-corpi__commercial-text svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }
  
  /* ========================================
     RESPONSIVE - TABLET Y DESKTOP
     ======================================== */
  @media screen and (min-width: 768px) {
    .card-product-corpi__content {
      padding: 24px;
      gap: 16px;
    }
    
    .card-product-corpi__title {
      font-size: 16px;
      min-height: 44px;
    }
    
    .card-product-corpi__price-current {
      font-size: 24px;
      gap: 10px;
    }
    
    .card-product-corpi__price-label {
      font-size: 11px;
      padding: 4px 10px;
    }
    
    .card-product-corpi__details-btn {
      padding: 14px 20px !important;
      font-size: 14px !important;
    }
    
    .card-product-corpi__features {
      gap: 10px;
      padding-top: 16px;
    }
    
    .card-product-corpi__feature {
      font-size: 13px;
      gap: 10px;
    }
    
    .card-product-corpi__feature svg {
      width: 18px;
      height: 18px;
    }
    
    .card-product-corpi__commercial-banner {
      padding: 12px 16px;
    }
    
    .card-product-corpi__commercial-text {
      font-size: 13px;
      gap: 8px;
    }
    
    .card-product-corpi__commercial-text svg {
      width: 18px;
      height: 18px;
    }
    
    .card-product-corpi__pricing-toggle {
      padding: 12px 16px;
      font-size: 13px;
    }
    
    .card-product-corpi__pricing-toggle svg {
      width: 16px;
      height: 16px;
    }
    
    .card-product-corpi__pricing-panel.open {
      padding: 16px;
    }
    
    .card-product-corpi__pricing-item {
      padding: 12px;
    }
    
    .card-product-corpi__pricing-qty {
      font-size: 12px;
    }
    
    .card-product-corpi__pricing-value {
      font-size: 14px;
    }
  }
  
  /* ========================================
     RESPONSIVE - MOBILE (CORRECCIÓN BOTÓN)
     ======================================== */
  @media screen and (max-width: 767px) {
    .card-product-corpi {
      border-radius: 12px;
      margin-bottom: 16px;
    }
    
    .card-product-corpi__badge-offer {
      font-size: 10px;
      padding: 5px 10px;
      top: 8px;
      left: 8px;
    }
    
    .card-product-corpi__details-btn {
      width: 80% !important;
      max-width: 160px !important;
      margin-left: auto !important;
      margin-right: auto !important;
      padding: 8px 12px !important;
      font-size: 12px !important;
      border-radius: 20px !important;
      display: flex !important;
      margin-top: 8px !important;
    }
    
    .card-product-corpi__details-btn svg {
      width: 14px !important;
      height: 14px !important;
    }
    
    .card-product-corpi__content {
      padding: 12px;
      gap: 6px;
    }
  }
  
  /* ========================================
     RESPONSIVE - SMALL MOBILE
     ======================================== */
  @media screen and (max-width: 480px) {
    .card-product-corpi__title {
      font-size: 14px;
      min-height: 38px;
    }
    
    .card-product-corpi__price-current {
      font-size: 20px;
      flex-direction: column;
      align-items: flex-start;
      gap: 4px;
    }
    
    .card-product-corpi__pricing-grid {
      grid-template-columns: 1fr;
    }
    
    .card-product-corpi__features {
      gap: 6px;
      padding-top: 10px;
    }
    
    .card-product-corpi__feature {
      font-size: 11px;
    }
    
    .card-product-corpi__details-btn {
      max-width: 140px !important;
      font-size: 11px !important;
    }
  }
  
  /* ========================================
     CARRUSEL "LO MÁS ELEGIDO"
     ======================================== */
  .corpi-carousel-container {
    overflow: hidden;
    position: relative;
    padding: 0 12px;
  }
  
  .corpi-carousel-track {
    display: flex;
    gap: 16px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding: 8px 4px 20px 4px;
  }
  
  .corpi-carousel-track::-webkit-scrollbar {
    display: none;
  }
  
  .corpi-carousel-item {
    flex: 0 0 auto;
    width: 260px;
    scroll-snap-align: start;
  }
  
  @media screen and (min-width: 768px) {
    .corpi-carousel-item {
      width: 280px;
    }
    
    .corpi-carousel-track {
      gap: 20px;
    }
  }
  
  @media screen and (max-width: 480px) {
    .corpi-carousel-item {
      width: 240px;
    }
    
    .corpi-carousel-track {
      gap: 12px;
    }
  }

  /* ============================================
     BADGE INSTALACIÓN INCLUIDA - SIEMPRE VISIBLE
     ============================================ */

  .card-product-corpi__badge-instalacion {
    display: inline-flex;
    align-items: center;
    padding: 3px 8px;
    border-radius: 10px;
    font-family: 'Montserrat', sans-serif;
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.4px;
    white-space: nowrap;
    background-color: #dcfce7;
    color: #166534;
    border: 1px solid #bbf7d0;
    line-height: 1;
    vertical-align: middle;
    cursor: help;
    flex-shrink: 0;
  }

  @media screen and (min-width: 768px) {
    .card-product-corpi__badge-instalacion {
      font-size: 10px;
      padding: 4px 10px;
    }
  }

  @media screen and (max-width: 767px) {
    .card-product-corpi__badge-instalacion {
      font-size: 8px;
      padding: 2px 6px;
      letter-spacing: 0.3px;
    }
  }

  .card-product-corpi__price-current {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
    row-gap: 4px;
  }

  @media screen and (max-width: 480px) {
    .card-product-corpi__price-current {
      gap: 4px;
      row-gap: 3px;
    }
    
    .card-product-corpi__badge-instalacion {
      font-size: 7.5px;
      padding: 2px 5px;
    }
    
    .card-product-corpi__price-label {
      font-size: 9px;
      padding: 2px 6px;
    }
  }

  .card-product-corpi__price-current {
    min-height: 28px;
  }
{%- endstyle -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">

{%- if card_product and card_product != empty -%}
  {%- liquid
    assign current_variant = card_product.selected_or_first_available_variant
    
    # Detectar si es césped
    assign is_grass = false
    if card_product.type == 'Césped' or card_product.tags contains 'cesped' or card_product.tags contains 'Césped'
      assign is_grass = true
    endif
    
    assign unit_type = card_product.metafields.custom.unidad | default: ''
    if unit_type == 'm2' or unit_type == 'm²'
      assign is_grass = true
    endif
    
    # Césped Maní por Docena (no incluye instalación)
    assign is_grass_mani_docena = false
    if card_product.title contains 'Maní' and card_product.title contains 'Docena'
      assign is_grass_mani_docena = true
    endif
    
    # Control de badge de oferta (manual)
assign show_offer_badge = card_product.metafields.custom.badge_oferta_manual

    
    # Determinar si incluye instalación (general)
    assign includes_installation = false
    if is_grass and is_grass_mani_docena == false
      assign includes_installation = true
    endif
  -%}

  <div class="card-product-corpi">
    <div class="card-product-corpi__media-wrapper">
      <a href="{{ card_product.url }}" aria-label="Ver {{ card_product.title | escape }}">
        {%- if card_product.featured_media -%}
          <img
            srcset="
              {%- if card_product.featured_media.width >= 165 -%}{{ card_product.featured_media | image_url: width: 165 }} 165w,{%- endif -%}
              {%- if card_product.featured_media.width >= 360 -%}{{ card_product.featured_media | image_url: width: 360 }} 360w,{%- endif -%}
              {%- if card_product.featured_media.width >= 533 -%}{{ card_product.featured_media | image_url: width: 533 }} 533w,{%- endif -%}
              {%- if card_product.featured_media.width >= 720 -%}{{ card_product.featured_media | image_url: width: 720 }} 720w,{%- endif -%}
              {{ card_product.featured_media | image_url }} {{ card_product.featured_media.width }}w
            "
            src="{{ card_product.featured_media | image_url: width: 533 }}"
            sizes="(min-width: 1200px) 280px, (min-width: 990px) 220px, (min-width: 750px) 280px, calc(50vw - 20px)"
            alt="{{ card_product.featured_media.alt | escape }}"
            class="card-product-corpi__media"
            loading="lazy"
            width="{{ card_product.featured_media.width }}"
            height="{{ card_product.featured_media.height }}"
          >
        {%- else -%}
          {{ 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </a>
      
      {%- if show_offer_badge -%}
        <span class="card-product-corpi__badge-offer">Oferta</span>
      {%- endif -%}
    </div>
    
    <div class="card-product-corpi__content">
      <h3 class="card-product-corpi__title">
        <a href="{{ card_product.url }}">{{ card_product.title | escape }}</a>
      </h3>
      
      <div class="card-product-corpi__prices">
        {%- if current_variant.compare_at_price > current_variant.price -%}
          <p class="card-product-corpi__price-compare">{{ current_variant.compare_at_price | money }}</p>
        {%- endif -%}
        <p class="card-product-corpi__price-current">
          {{ current_variant.price | money }}
          
          {%- if show_offer_badge -%}

            <span class="card-product-corpi__price-label">PROMO</span>
          {%- endif -%}

          {%- comment %} BADGE SEO: Solo para productos específicos de césped con instalación {% endcomment -%}
          {%- assign handles_con_instalacion = 'cesped-esmeralda,cesped-siempre-verde,cesped-kavaju,piso-ecologico,cesped-mani,' | split: ',' -%}
          {%- if handles_con_instalacion contains card_product.handle -%}
            <span class="card-product-corpi__badge-instalacion" title="El precio incluye instalación profesional">
              INCLUYE INSTALACIÓN
            </span>
          {%- endif -%}

          {%- if is_grass -%}
            <span class="card-product-corpi__price-unit">/m²</span>
          {%- elsif unit_type != blank -%}
            <span class="card-product-corpi__price-unit">/{{ unit_type }}</span>
          {%- endif -%}
        </p>
      </div>
      
      {%- if is_grass -%}
        <button class="card-product-corpi__pricing-toggle" onclick="this.classList.toggle('active'); this.nextElementSibling.classList.toggle('open')">
          <span>Ver precios por cantidad</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </button>
        <div class="card-product-corpi__pricing-panel">
          <div class="card-product-corpi__pricing-grid">
            <div class="card-product-corpi__pricing-item">
              <p class="card-product-corpi__pricing-qty">1-10 m²</p>
              <p class="card-product-corpi__pricing-value">{{ current_variant.price | money }}</p>
            </div>
            <div class="card-product-corpi__pricing-item">
              <p class="card-product-corpi__pricing-qty">11-50 m²</p>
              <p class="card-product-corpi__pricing-value">{{ current_variant.price | times: 0.95 | money }}</p>
            </div>
            <div class="card-product-corpi__pricing-item">
              <p class="card-product-corpi__pricing-qty">51-100 m²</p>
              <p class="card-product-corpi__pricing-value">{{ current_variant.price | times: 0.90 | money }}</p>
            </div>
            <div class="card-product-corpi__pricing-item">
              <p class="card-product-corpi__pricing-qty">+100 m²</p>
              <p class="card-product-corpi__pricing-value">{{ current_variant.price | times: 0.85 | money }}</p>
            </div>
          </div>
        </div>
      {%- endif -%}
      
      <a href="{{ card_product.url }}" class="card-product-corpi__details-btn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.35-4.35"></path>
        </svg>
        Ver Detalles
      </a>
      
      <div class="card-product-corpi__features">
        {%- if includes_installation -%}
          <div class="card-product-corpi__feature">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span>Garantía de 12 meses</span>
          </div>
        {%- endif -%}
        
        {%- if is_grass -%}
          <div class="card-product-corpi__feature">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span>Envío gratis en Asunción</span>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>

{%- else -%}
  <div class="card-product-corpi">
    <div class="card-product-corpi__media-wrapper">
      {{ 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
    </div>
    <div class="card-product-corpi__content">
      <h3 class="card-product-corpi__title">
        <a role="link" aria-disabled="true">{{ 'onboarding.product_title' | t }}</a>
      </h3>
      <div class="card-product-corpi__prices">
        <p class="card-product-corpi__price-current">Gs. 0</p>
      </div>
    </div>
  </div>
{%- endif -%}