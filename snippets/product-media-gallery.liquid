{% comment %}
  Galería estilo Inverfin - Imagen grande + thumbnails abajo
{% endcomment %}

{%- liquid
  assign media_count = product.media.size
-%}

<div class="product-gallery-inverfin">
  {% comment %} Imagen principal grande {% endcomment %}
  <div class="main-image-container">
    <img 
      id="main-product-image"
      src="{{ product.featured_image | image_url: width: 800 }}" 
      alt="{{ product.featured_image.alt | escape }}"
      loading="eager"
    >
    {% if media_count > 1 %}
      <button class="nav-arrow prev" onclick="changeImage(-1)">‹</button>
      <button class="nav-arrow next" onclick="changeImage(1)">›</button>
    {% endif %}
  </div>

  {% comment %} Thumbnails {% endcomment %}
  {% if media_count > 1 %}
    <div class="thumbnails-container">
      {%- for media in product.media -%}
        <img 
          src="{{ media | image_url: width: 150 }}" 
          alt="{{ media.alt | escape }}"
          class="thumb {% if forloop.first %}active{% endif %}"
          onclick="setMainImage({{ forloop.index0 }})"
          data-index="{{ forloop.index0 }}"
        >
      {%- endfor -%}
    </div>
  {% endif %}
</div>

<script>
  const images = [
    {%- for media in product.media -%}
      "{{ media | image_url: width: 800 }}"{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ];
  let currentIndex = 0;

  function setMainImage(index) {
    currentIndex = index;
    document.getElementById('main-product-image').src = images[index];
    document.querySelectorAll('.thumb').forEach((t, i) => {
      t.classList.toggle('active', i === index);
    });
  }

  function changeImage(direction) {
    currentIndex = (currentIndex + direction + images.length) % images.length;
    setMainImage(currentIndex);
  }
</script>

<style>
  .product-gallery-inverfin {
    max-width: 500px;
    margin: 0 auto;
  }
  .main-image-container {
    position: relative;
    background: #f5f5f5;
    border-radius: 8px;
    overflow: hidden;
  }
  .main-image-container img {
    width: 100%;
    height: 500px;
    object-fit: contain;
    display: block;
  }
  .nav-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255,255,255,0.9);
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    font-size: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .nav-arrow.prev { left: 10px; }
  .nav-arrow.next { right: 10px; }
  .thumbnails-container {
    display: flex;
    gap: 10px;
    margin-top: 15px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .thumbnails-container img {
    width: 70px;
    height: 70px;
    object-fit: cover;
    border-radius: 6px;
    cursor: pointer;
    border: 2px solid transparent;
    opacity: 0.7;
    transition: all 0.2s;
  }
  .thumbnails-container img:hover,
  .thumbnails-container img.active {
    border-color: #25D366;
    opacity: 1;
  }
  @media (max-width: 749px) {
    .main-image-container img { height: 350px; }
    .thumbnails-container img { width: 60px; height: 60px; }
  }
</style>